# WhatsApp Group Bot Configuration

# Prefijo para comandos del bot
BOT_PREFIX=!

# Límite de advertencias (predeterminado 2)
MAX_WARNINGS=2

# Mensaje de auto-respuesta para chats privados
AUTO_REPLY_MSG="Hola 👋\nEste es un bot de administración de grupos.\n\nPara ventas o consultas directas, por favor contáctame a mi número principal:\n📱 wa.me/51956815890"

# Gemini AI API Key (Consíguela gratis en aistudio.google.com)
GEMINI_API_KEY=AIzaSy...!

# Número del owner (con código de país, sin + ni espacios)
# Ejemplo: 5491112345678
OWNER_NUMBER=

# Entorno
NODE_ENV=development
